{
  "version": "1.0.0",
  "description": "OpenClaw 基础运行与故障修复 Genes",
  "genes": [
    {
      "id": "gateway-restart-gene",
      "name": "网关重启修复",
      "description": "通过重启修复网关服务",
      "capsule_id": "openclaw-gateway-repair",
      "mutation": {
        "type": "command_sequence",
        "commands": [
          "openclaw gateway stop",
          "sleep 2",
          "pkill -f 'openclaw.*gateway' 2>/dev/null || true",
          "sleep 1",
          "openclaw gateway start"
        ]
      },
      "validation": [
        "sleep 3",
        "openclaw gateway status | grep -i 'running\|active'"
      ],
      "rollback": [
        "openclaw gateway stop",
        "echo 'Gateway stopped for manual inspection'"
      ]
    },
    {
      "id": "config-backup-restore-gene",
      "name": "配置备份恢复",
      "description": "从备份恢复配置文件",
      "capsule_id": "openclaw-config-repair",
      "mutation": {
        "type": "file_operation",
        "backup": "~/.openclaw/config.json",
        "restore_from": "~/.openclaw/config.json.backup"
      },
      "validation": [
        "python3 -c \"import json; json.load(open('~/.openclaw/config.json'))\" && echo 'Config valid'"
      ],
      "rollback": [
        "cp ~/.openclaw/config.json.backup ~/.openclaw/config.json"
      ]
    },
    {
      "id": "skill-reload-gene",
      "name": "Skill 重新加载",
      "description": "重新加载所有 Skills",
      "capsule_id": "openclaw-skill-repair",
      "mutation": {
        "type": "command_sequence",
        "commands": [
          "openclaw skills reload",
          "sleep 2"
        ]
      },
      "validation": [
        "openclaw skills list | head -5"
      ],
      "rollback": []
    },
    {
      "id": "memory-optimize-gene",
      "name": "内存优化",
      "description": "优化内存使用，清理缓存",
      "capsule_id": "openclaw-stability-harden",
      "mutation": {
        "type": "command_sequence",
        "commands": [
          "openclaw cache clear",
          "echo 3 > /proc/sys/vm/drop_caches 2>/dev/null || true"
        ]
      },
      "validation": [
        "free -h 2>/dev/null || vm_stat | head -5"
      ],
      "rollback": []
    },
    {
      "id": "log-cleanup-gene",
      "name": "日志清理",
      "description": "清理 7 天前的日志文件",
      "capsule_id": "openclaw-log-cleanup",
      "mutation": {
        "type": "command_sequence",
        "commands": [
          "find ~/.openclaw/logs/ -name '*.log' -mtime +7 -delete 2>/dev/null || true",
          "find ~/.openclaw/logs/ -name '*.json' -mtime +7 -delete 2>/dev/null || true",
          "echo 'Old logs cleaned'"
        ]
      },
      "validation": [
        "du -sh ~/.openclaw/logs/"
      ],
      "rollback": []
    }
  ]
}
