{
  "version": "1.0.0",
  "description": "OpenClaw 基础运行与故障修复 Capsules",
  "capsules": [
    {
      "id": "openclaw-gateway-repair",
      "name": "OpenClaw Gateway 修复",
      "description": "修复 OpenClaw 网关启动错误和服务不稳定问题",
      "category": "repair",
      "signals": [
        "gateway start failed",
        "openclaw gateway error",
        "gateway timeout",
        "connection refused",
        "EADDRINUSE",
        "gateway crash"
      ],
      "validation": [
        "openclaw gateway status",
        "curl -s http://localhost:8080/health || echo 'Health check failed'"
      ],
      "dna": {
        "emoji": "🧬",
        "priority": "critical",
        "auto_apply": false
      }
    },
    {
      "id": "openclaw-config-repair",
      "name": "OpenClaw 配置修复",
      "description": "修复配置文件错误和配置加载问题",
      "category": "repair",
      "signals": [
        "config error",
        "configuration failed",
        "invalid config",
        "config.json error",
        "yaml parse error"
      ],
      "validation": [
        "openclaw config validate || echo 'Config invalid'",
        "cat ~/.openclaw/config.json | python3 -m json.tool > /dev/null && echo 'JSON valid'"
      ],
      "dna": {
        "emoji": "🧬",
        "priority": "high",
        "auto_apply": false
      }
    },
    {
      "id": "openclaw-skill-repair",
      "name": "OpenClaw Skill 修复",
      "description": "修复 Skill 加载失败和运行时错误",
      "category": "repair",
      "signals": [
        "skill load failed",
        "skill error",
        "module not found",
        "skill crash",
        "SKILL.md error"
      ],
      "validation": [
        "ls ~/.openclaw/workspace/skills/ | head -5",
        "openclaw skills list 2>&1 | head -10"
      ],
      "dna": {
        "emoji": "🧬",
        "priority": "medium",
        "auto_apply": false
      }
    },
    {
      "id": "openclaw-stability-harden",
      "name": "OpenClaw 稳定性加固",
      "description": "提升 OpenClaw 服务的稳定性和可靠性",
      "category": "harden",
      "signals": [
        "service unstable",
        "frequent restart",
        "memory leak",
        "high cpu usage",
        "slow response"
      ],
      "validation": [
        "ps aux | grep openclaw | grep -v grep | wc -l",
        "openclaw status 2>&1 | grep -i 'running\|active'"
      ],
      "dna": {
        "emoji": "🧬",
        "priority": "medium",
        "auto_apply": false
      }
    },
    {
      "id": "openclaw-log-cleanup",
      "name": "OpenClaw 日志清理",
      "description": "清理过期日志文件，释放磁盘空间",
      "category": "maintenance",
      "signals": [
        "disk full",
        "log file too large",
        "cleanup needed",
        "storage warning"
      ],
      "validation": [
        "du -sh ~/.openclaw/logs/ 2>/dev/null || echo 'No logs dir'",
        "find ~/.openclaw/logs/ -name '*.log' -mtime +7 | wc -l"
      ],
      "dna": {
        "emoji": "🧬",
        "priority": "low",
        "auto_apply": true
      }
    }
  ]
}
